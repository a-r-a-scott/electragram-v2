# =============================================================================
# Electragram v2 — Environment Variables
# Copy this file to .env and fill in values for local development
# =============================================================================

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Database (RDS PostgreSQL) ---
DATABASE_URL=postgresql://electragram:password@localhost:5432/electragram_dev

# --- Redis (ElastiCache) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Paths to RSA-2048 PEM files — generated by scripts/setup-local.sh
# The files are stored in the keys/ directory (git-ignored).
JWT_PRIVATE_KEY_FILE=./keys/jwt-private.pem
JWT_PUBLIC_KEY_FILE=./keys/jwt-public.pem

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- SendGrid ---
SENDGRID_API_KEY=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- AWS SQS Queue URLs (LocalStack for local dev) ---
SQS_ENDPOINT=http://localhost:4566
SQS_DELIVERY_EMAIL_URL=http://localhost:4566/000000000000/delivery-email
SQS_DELIVERY_SMS_URL=http://localhost:4566/000000000000/delivery-sms
SQS_DELIVERY_WHATSAPP_URL=http://localhost:4566/000000000000/delivery-whatsapp
SQS_CHAT_INBOUND_URL=http://localhost:4566/000000000000/chat-inbound
SQS_DELIVERY_STATUS_URL=http://localhost:4566/000000000000/delivery-status
SQS_MEDIA_PROCESSING_URL=http://localhost:4566/000000000000/media-processing

# --- AWS SNS ---
SNS_ENDPOINT=http://localhost:4566
SNS_DELIVERY_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:delivery-events

# --- AWS EventBridge ---
EVENTBRIDGE_ENDPOINT=http://localhost:4566
EVENTBRIDGE_BUS_NAME=electragram-events

# --- AWS S3 ---
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=electragram-media-dev

# --- AWS Secrets Manager ---
SECRETS_ENDPOINT=http://localhost:4566

# --- Service ports (local dev) ---
IDENTITY_SERVICE_URL=http://localhost:3001
CONTACTS_SERVICE_URL=http://localhost:3002
EVENTS_SERVICE_URL=http://localhost:3003
MESSAGING_SERVICE_URL=http://localhost:3004
CHAT_SERVICE_URL=http://localhost:3007
INTEGRATIONS_SERVICE_URL=http://localhost:3008
DESIGN_SERVICE_URL=http://localhost:3009
ANALYTICS_SERVICE_URL=http://localhost:3010

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3007/chat/ws

# --- Environment ---
NODE_ENV=development
LOG_LEVEL=debug
