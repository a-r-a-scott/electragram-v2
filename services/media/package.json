{
  "name": "@electragram/media-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage --testPathPattern='tests/unit'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@electragram/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "drizzle-orm": "^0.38.3",
    "jose": "^5.2.0",
    "pg": "^8.13.3",
    "csv-parse": "^5.6.0",
    "zod": "^3.24.1",
    "pino": "^9.6.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@electragram/config": "workspace:*",
    "@electragram/test-utils": "workspace:*",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
