{
  "name": "@electragram/design-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage --reporter=verbose tests/unit",
    "test:integration": "vitest run --coverage --reporter=verbose tests/integration",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@electragram/types": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.3",
    "jose": "^5.9.6",
    "zod": "^3.24.1",
    "pino": "^9.6.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@electragram/config": "workspace:*",
    "@electragram/test-utils": "workspace:*",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "testcontainers": "^10.16.0"
  }
}
